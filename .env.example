# Copy to .env. Default local DB matches docker-compose `postgres` service (see docker-compose.yml).

# Local npm run dev — host must be localhost
DATABASE_URL="postgresql://postgres:1234@localhost:5432/advocade?schema=public"

# App running inside Docker Compose — use the postgres service hostname
# DATABASE_URL="postgresql://postgres:1234@postgres:5432/advocade?schema=public"

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# MinIO server — used by `minio` / `minio-init` / app (compose interpolation).
# Local: set here. Production via GitHub Actions: also add repo secrets MINIO_ROOT_USER, MINIO_ROOT_PASSWORD,
# MINIO_BUCKET (optional; default `uploads` in compose) — deploy workflow forwards them to the VPS for `docker compose`.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# Example: MINIO_ROOT_PASSWORD="your_password_with_&_chars"

# MinIO: `npm run dev` on the machine — use localhost (port published by compose).
# The `nextjs` service in docker-compose overrides MINIO_ENDPOINT to http://minio:9000.
MINIO_ENDPOINT=http://localhost:9000
# Usually the same as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD (see docker-compose MinIO services).
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Bucket name used by the app and created by `minio-init` (older compose often had no init — create the same name in console or keep this).
MINIO_BUCKET=uploads
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
