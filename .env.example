# Copy to .env. Default local DB matches docker-compose `postgres` service (see docker-compose.yml).

# Local npm run dev — host must be localhost
DATABASE_URL="postgresql://postgres:1234@localhost:5432/advocade?schema=public"

# App running inside Docker Compose — use the postgres service hostname
# DATABASE_URL="postgresql://postgres:1234@postgres:5432/advocade?schema=public"

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# MinIO on host (compose publishes port 9000)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=uploads
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
